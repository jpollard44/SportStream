rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Public read for all uploaded media
    match /{allPaths=**} {
      allow read: if true;
    }

    // Club logos — any authenticated user
    match /clubs/{clubId}/logo {
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024;
    }

    // Player photos
    match /clubs/{clubId}/players/{playerId} {
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024;
    }

    // Tournament cover photos
    match /tournaments/{tourId}/cover {
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
    }

    // League cover photos
    match /leagues/{leagueId}/cover {
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
    }

    // Highlight video clips — up to 50 MB, authenticated users only
    match /highlights/{highlightId}/clip.mp4 {
      allow write: if request.auth != null
        && request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }
  }
}
