rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: only readable/writable by the owner
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Clubs: public read (team pages), admin write
    match /clubs/{clubId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.adminIds;

      // Players subcollection — public read, admin write
      match /players/{playerId} {
        allow read: if true;
        allow write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/clubs/$(clubId)).data.adminIds;
      }
    }

    // Games: public read, scorekeeper write
    match /games/{gameId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (
        request.auth.uid == resource.data.scorekeeperId ||
        (resource.data.clubId != null &&
          request.auth.uid in get(/databases/$(database)/documents/clubs/$(resource.data.clubId)).data.adminIds)
      );

      match /plays/{playId} {
        allow read: if true;
        allow create: if request.auth != null &&
          request.auth.uid == get(/databases/$(database)/documents/games/$(gameId)).data.scorekeeperId;
        allow update: if request.auth != null && request.auth.uid == resource.data.createdBy;
        allow delete: if request.auth != null;
      }
    }

    // Tournaments: public read, host write, open team registration
    match /tournaments/{tourId} {
      allow read: if true;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.hostId;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.hostId;

      match /teams/{teamId} {
        allow read: if true;
        allow create: if true;
        allow update, delete: if
          (request.auth != null && request.auth.uid ==
            get(/databases/$(database)/documents/tournaments/$(tourId)).data.hostId) ||
          (request.auth != null && request.auth.uid == resource.data.managerId) ||
          resource.data.managerId == null;
      }
    }

    // Leagues: public read, host write, open team registration
    match /leagues/{leagueId} {
      allow read: if true;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.hostId;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.hostId;

      match /teams/{teamId} {
        allow read: if true;
        allow create: if true;
        allow update, delete: if
          (request.auth != null && request.auth.uid ==
            get(/databases/$(database)/documents/leagues/$(leagueId)).data.hostId) ||
          (request.auth != null && request.auth.uid == resource.data.managerId) ||
          resource.data.managerId == null;
      }
    }
  }
}
