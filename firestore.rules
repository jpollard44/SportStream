rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function clubData(clubId) {
      return get(/databases/$(database)/documents/clubs/$(clubId)).data;
    }

    function isClubAdmin(clubId) {
      return signedIn() && request.auth.uid in clubData(clubId).adminIds;
    }

    function gameData(gameId) {
      return get(/databases/$(database)/documents/games/$(gameId)).data;
    }

    // Scorekeeper of the game, or an admin of the game's club
    function canManageGame(game) {
      return signedIn() && (
        request.auth.uid == game.scorekeeperId ||
        (game.clubId != null && request.auth.uid in clubData(game.clubId).adminIds)
      );
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // Users: only readable/writable by the owner
    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    // Clubs: public read (team pages), admin write
    match /clubs/{clubId} {
      allow read: if true;
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.ownerId
        && request.auth.uid in request.resource.data.adminIds
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100;
      // Admins can edit, but ownership can never be reassigned
      allow update: if signedIn()
        && request.auth.uid in resource.data.adminIds
        && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if signedIn() && request.auth.uid in resource.data.adminIds;

      // Players subcollection — public read, admin write.
      // Linking a player profile to a user account (the `uid` field) happens
      // through the claimInvite Cloud Function, which bypasses these rules.
      match /players/{playerId} {
        allow read: if true;
        allow write: if isClubAdmin(clubId);
      }
    }

    // Games: public read, scorekeeper/club-admin write
    match /games/{gameId} {
      allow read: if true;
      // Live games are created by their scorekeeper; scheduled stubs
      // (scorekeeperId == null) only by an admin of the club they belong to.
      allow create: if signedIn()
        && request.resource.data.homeScore == 0
        && request.resource.data.awayScore == 0
        && (
          request.resource.data.scorekeeperId == request.auth.uid ||
          (request.resource.data.scorekeeperId == null
            && request.resource.data.clubId is string
            && isClubAdmin(request.resource.data.clubId))
        );
      allow update: if canManageGame(resource.data)
        // Anyone (including signed-out viewers) may bump the view counter by 1
        || (changedKeys().hasOnly(['views'])
            && request.resource.data.views == resource.data.get('views', 0) + 1);
      allow delete: if canManageGame(resource.data);

      match /plays/{playId} {
        allow read: if true;
        allow create: if signedIn()
          && request.auth.uid == gameData(gameId).scorekeeperId
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.undone == false;
        // Undo is a soft delete — only the `undone` flag may change,
        // and only by the play's author or the game's scorekeeper
        allow update: if signedIn()
          && (request.auth.uid == resource.data.createdBy
              || request.auth.uid == gameData(gameId).scorekeeperId)
          && changedKeys().hasOnly(['undone']);
        // Hard deletes only happen as part of deleting the whole game
        allow delete: if canManageGame(gameData(gameId));
      }
    }

    // Tournaments: public read, host write, open team registration
    match /tournaments/{tourId} {
      allow read: if true;
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.hostId;
      allow update, delete: if signedIn()
        && request.auth.uid == resource.data.hostId;

      match /teams/{teamId} {
        allow read: if true;
        // Registration is open to signed-out managers by design (public join
        // page), but must be a fresh pending entry that isn't claimed for
        // someone else's account.
        allow create: if request.resource.data.status == 'pending'
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 100
          && (request.resource.data.managerId == null
              || (signedIn() && request.resource.data.managerId == request.auth.uid));
        allow update, delete: if signedIn() && (
          request.auth.uid == get(/databases/$(database)/documents/tournaments/$(tourId)).data.hostId ||
          request.auth.uid == resource.data.managerId
        );
      }
    }

    // Invites: the unguessable token itself is the capability, so direct
    // lookups are public — but the collection must never be listable, and
    // claiming happens through the claimInvite Cloud Function.
    match /invites/{token} {
      allow get: if true;
      allow list: if false;
      allow create: if signedIn()
        && request.resource.data.claimed == false
        && isClubAdmin(request.resource.data.clubId);
      allow update, delete: if false;
    }

    // Leagues: public read, host write, open team registration
    match /leagues/{leagueId} {
      allow read: if true;
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.hostId;
      allow update, delete: if signedIn()
        && request.auth.uid == resource.data.hostId;

      match /teams/{teamId} {
        allow read: if true;
        allow create: if request.resource.data.status == 'pending'
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 100
          && (request.resource.data.managerId == null
              || (signedIn() && request.resource.data.managerId == request.auth.uid));
        allow update, delete: if signedIn() && (
          request.auth.uid == get(/databases/$(database)/documents/leagues/$(leagueId)).data.hostId ||
          request.auth.uid == resource.data.managerId
        );
      }
    }

    // Highlights: public read; created by Cloud Functions (bypass rules) or
    // signed-in users; updates limited to reaction counters and nominations
    match /highlights/{highlightId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.reactionCount == 0
        && request.resource.data.nominatedForAward == false;
      allow update: if signedIn() && (
        // Reaction toggles — paired with the user's own userReactions doc below
        changedKeys().hasOnly(['reactions', 'reactionCount']) ||
        // Nominating for the weekly award (one-way flag)
        (changedKeys().hasOnly(['nominatedForAward'])
          && request.resource.data.nominatedForAward == true)
      );

      match /userReactions/{uid} {
        allow read: if true;
        allow write: if signedIn() && request.auth.uid == uid;
      }
    }

    // Weekly top 10 awards: public read, written by Cloud Functions only
    match /weeklyTop10/{weekKey} {
      allow read: if true;
      allow write: if false;
    }
  }
}
